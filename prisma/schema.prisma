generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  products     Product[]
}

model Waitlist {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String?
  source           String         @default("landing")
  status           WaitlistStatus @default(PENDING)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  inviteCode       String?        @unique
  inviteCodeUsedAt DateTime?

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Product {
  id                String             @id @default(cuid())
  userId            String
  name              String
  status            ProductStatus      @default(PRE_LAUNCH)
  launchDate        DateTime?
  description       String?
  category          String?
  targetAudience    String?
  businessModel     String?
  website           String?
  launchStatus      String?
  logoUrl           String?
  launchGoals       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  activationFunnels ActivationFunnel[]
  goals             Goal[]
  growthChecklists  GrowthChecklist[]
  routines          GrowthRoutine[]
  integrations      Integration[]
  launchChecklists  LaunchChecklist[]
  metrics           Metric[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  retentionCohorts  RetentionCohort[]
  tasks             Task[]
  timelineEvents    TimelineEvent[]

  @@index([userId])
}

model LaunchChecklist {
  id           String         @id @default(cuid())
  productId    String
  category     LaunchCategory
  title        String
  description  String?
  completed    Boolean        @default(false)
  completedAt  DateTime?
  order        Int            @default(0)
  priority     Priority       @default(MEDIUM)
  linkedTaskId String?        @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  linkedTask   Task?          @relation("ChecklistTask", fields: [linkedTaskId], references: [id])
  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model GrowthChecklist {
  id          String         @id @default(cuid())
  productId   String
  category    GrowthCategory
  title       String
  description String?
  completed   Boolean        @default(false)
  completedAt DateTime?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Task {
  id                  String           @id @default(cuid())
  productId           String
  title               String
  description         String?
  status              TaskStatus       @default(TODO)
  priority            Priority         @default(MEDIUM)
  dueDate             DateTime?
  order               Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  launchChecklistItem LaunchChecklist? @relation("ChecklistTask")
  product             Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, status])
}

model Metric {
  id                  String       @id @default(cuid())
  productId           String
  date                DateTime
  dau                 Int?
  mau                 Int?
  mrr                 Float?
  activeSubscriptions Int?
  newSignups          Int?
  churnedUsers        Int?
  activationRate      Float?
  source              MetricSource @default(MANUAL)
  createdAt           DateTime     @default(now())
  product             Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([productId, date])
}

model RetentionCohort {
  id             String   @id @default(cuid())
  productId      String
  cohortDate     DateTime
  usersCount     Int
  retentionDay1  Float?
  retentionDay7  Float?
  retentionDay30 Float?
  retentionDay60 Float?
  retentionDay90 Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, cohortDate])
  @@index([productId])
}

model ActivationFunnel {
  id             String         @id @default(cuid())
  productId      String
  date           DateTime
  step           ActivationStep
  count          Int
  conversionRate Float?
  createdAt      DateTime       @default(now())
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date, step])
  @@index([productId, date])
}

model GrowthRoutine {
  id              String    @id @default(cuid())
  productId       String
  title           String
  description     String?
  frequency       Frequency
  lastCompletedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Goal {
  id           String   @id @default(cuid())
  productId    String
  title        String
  targetValue  Float
  currentValue Float    @default(0)
  unit         String
  startDate    DateTime
  endDate      DateTime
  completed    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model TimelineEvent {
  id          String    @id @default(cuid())
  productId   String
  eventType   EventType
  title       String
  description String?
  date        DateTime
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, date])
}

model Integration {
  id         String              @id @default(cuid())
  productId  String
  provider   IntegrationProvider
  status     IntegrationStatus   @default(DISCONNECTED)
  config     String?
  lastSyncAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  product    Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  syncJobs   SyncJob[]

  @@unique([productId, provider])
  @@index([productId])
}

model SyncJob {
  id            String      @id @default(cuid())
  integrationId String
  status        SyncStatus
  startedAt     DateTime    @default(now())
  completedAt   DateTime?
  error         String?
  recordsSynced Int?
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
}

enum WaitlistStatus {
  PENDING
  APPROVED
  INVITED
  REJECTED
}

enum ProductStatus {
  PRE_LAUNCH
  LAUNCHED
  GROWING
}

enum LaunchCategory {
  PRODUCT
  MARKETING
  LEGAL
  TECH
}

enum GrowthCategory {
  ACQUISITION
  ACTIVATION
  RETENTION
  REVENUE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum MetricSource {
  MANUAL
  INTEGRATION
}

enum ActivationStep {
  SIGNUP
  ONBOARDING
  FIRST_ACTION
  ACTIVATED
}

enum Frequency {
  WEEKLY
  MONTHLY
}

enum EventType {
  LAUNCH
  MILESTONE
  GOAL_COMPLETED
  INTEGRATION_CONNECTED
  METRIC_THRESHOLD
  CUSTOM
}

enum IntegrationProvider {
  STRIPE
  GA4
  MIXPANEL
  SEGMENT
  AMPLITUDE
  POSTHOG
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}
